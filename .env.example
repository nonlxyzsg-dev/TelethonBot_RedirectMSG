# =========================================================================
# Шаблон конфигурации TelethonBot_RedirectMSG
# Скопируйте этот файл в .env (без .example) и заполните значения.
#
# ВАЖНО про слои настроек:
#   1. Этот файл (.env.example) — самые нижние дефолты.
#   2. Ваш .env — перетирает .env.example.
#   3. Переменные окружения (os.environ) — ещё выше.
#   4. config.json (если положите рядом) — поверх всего.
#
# То есть если у вас уже есть рабочий config.json (например, со списком
# источников и tags_for_topics) — просто положите его рядом, .env
# заполнять не обязательно.
# =========================================================================

# --- Telegram API (обязательно) ------------------------------------------
# Получите на https://my.telegram.org → API development tools
API_ID=
API_HASH=

# --- Источники (обязательно) ---------------------------------------------
# Один или несколько id чатов через запятую. Узнать ID можно в @userinfobot.
# Для супергрупп/каналов ID начинается с -100...
# Примеры:
#   MONITORED_CHAT_IDS=-1001234567890
#   MONITORED_CHAT_IDS=-1001234567890,738212658,4122528496
MONITORED_CHAT_IDS=

# --- Получатель (обязательно) --------------------------------------------
# ID одного чата/группы, куда пересылаем сообщения.
CHAT_ID_TO_REDIRECT_MESSAGES=

# --- Маршрутизация по темам форума (опционально) -------------------------
# Если получатель — форум-группа с темами и нужно раскладывать сообщения
# по темам в зависимости от хэштегов:
#   1. Установите USE_TOPICS=true.
#   2. Положите рядом routes.json с правилами вида
#      {"<topic_id>": {"include": {"or": ["#tag"]}, "exclude": {"or": []}}}.
# Альтернатива: используйте config.json с секцией tags_for_topics —
# она перетирает USE_TOPICS и routes.json (см. README).
USE_TOPICS=false

# --- Параметры устройства (менять НЕ рекомендуется после первого входа) --
# Telegram запоминает эти значения для вашей сессии. Изменение может
# привести к уведомлениям о "новом устройстве" и завершению других сессий.
DEVICE_MODEL=Custom Device
SYSTEM_VERSION=4.16.30-vxCUSTOM
APP_VERSION=1.0

# --- Пути и имена -------------------------------------------------------
# Папка для временных скачанных медиафайлов (создаётся автоматически)
TEMP_FILES_DIR=temp_files
# Имя файла сессии (без расширения). Рядом появится SESSION_NAME.session
SESSION_NAME=telethon

# --- Логирование --------------------------------------------------------
# Уровни: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
